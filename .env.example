# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/ecommerce_delivery
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/ecommerce_delivery
MONGO_URI=mongodb://localhost:27017/ecommerce_delivery

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong secrets:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_64_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_STRONG_SECRET_64_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CLIENT_ORIGIN=http://localhost:3000

# ─── Email (Nodemailer) ────────────────────────────────────────────────────────
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=your_ethereal_user
EMAIL_PASS=your_ethereal_pass
EMAIL_FROM=noreply@ecommerce-delivery.com

# ─── Uploads ──────────────────────────────────────────────────────────────────
UPLOAD_PATH=uploads
MAX_FILE_SIZE_MB=5

# ─── Delivery radius ──────────────────────────────────────────────────────────
# Default service radius in kilometres
DEFAULT_DELIVERY_RADIUS_KM=15

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
